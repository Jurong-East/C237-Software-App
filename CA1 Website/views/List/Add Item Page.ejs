<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Adding Game Backlog</title>

    <style>
        body {
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
                        url("/Images/ListPage.gif") no-repeat center center/cover;
            min-height: 100vh;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            backdrop-filter: blur(5px);
            z-index: -1;
        }
    </style>
</head>

<body>
    <%- include('../partials/header') %>

    <div class="container mt-4 text-white" style="max-width: 600px;">
        <h2 class="mb-4">🎮 Add to Your Backlog</h2>

        <form action="/games/add" method="post">

            <div class="mb-3">
                <label for="title">Game Name:</label>
                <input type="text" class="form-control" id="title" name="title" placeholder="Enter Game Name">
            </div>

            <div class="mb-3">
                <label for="platform">Platform:</label>
                <select class="form-select" id="platform" name="platform">
                    <option value="">Select Platform</option>
                    <option value="PC">PC</option>
                    <option value="PS5">PS5</option>
                    <option value="PS4">PS4</option>
                    <option value="Xbox">Xbox</option>
                    <option value="Nintendo Switch">Nintendo Switch</option>
                    <option value="Mobile">Mobile</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="status">Status:</label>
                <select class="form-select" id="status" name="status">
                    <option value="">Select Status</option>
                    <option value="Playing">Playing</option>
                    <option value="Completed">Completed</option>
                    <option value="On Hold">On Hold</option>
                    <option value="Dropped">Dropped</option>
                    <option value="Plan to Play">Plan to Play</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="genre">Genre:</label>
                <input type="text" class="form-control" id="genre" name="genre" placeholder="Enter Genre">
            </div>

            <div class="mb-3">
                <label for="notes">Notes:</label>
                <textarea class="form-control" id="notes" name="notes" rows="3" placeholder="Any notes?"></textarea>
            </div>

            <div class="mb-3">
                <label for="rating">Rating:</label>
                <select class="form-select" id="rating" name="rating">
                    <option value="1">⭐★★★★ 1</option>
                    <option value="2">⭐⭐★★★ 2</option>
                    <option value="3">⭐⭐⭐★★ 3</option>
                    <option value="4">⭐⭐⭐⭐★ 4</option>
                    <option value="5">⭐⭐⭐⭐⭐ 5</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="image">Game Image URL:</label>
                <input type="text" class="form-control" id="image" name="image" placeholder="Paste image URL here (optional)">
                <small class="text-white-50">Right-click any game image online → Copy Image Address → Paste here</small>
            </div>

            <button type="submit" class="btn btn-primary">Add Game</button>

        </form>
    </div>

</body>
</html>