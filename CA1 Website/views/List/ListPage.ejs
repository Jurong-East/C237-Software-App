<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
                        url("/Images/ListPage.gif") no-repeat center center/cover;
            min-height: 100vh;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            backdrop-filter: blur(5px);
            z-index: -1;
        }
    </style>

    <title>Game Backlog</title>
</head>

<body>
    <%- include('../partials/header') %>

    <div class="container mt-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-white fw-bold">My Game Backlog</h2>
            <a href="/Add" class="btn btn-success">+ Add Game</a>
        </div>

        <div class="row g-4">
            <% games.forEach(game => { %>

            <div class="col-md-4">
                <div class="card h-100 shadow" style="background-color: rgba(0, 0, 0, .7); color: white; border: none;">

                    <img src="<%= game.image %>" 
                    class="card-img-top" 
                    alt="<%= game.title %>"
                    style="height: 300px; object-fit: cover;">

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title"><%= game.title %></h5>

                        <p class="card-text">
                            <strong>Platform:</strong> <%= game.platform %> <br>
                            <strong>Status:</strong> <%= game.status %> <br>
                            <strong>Rating:</strong>
                            <% for(let i = 1; i <= 5; i++) { %>
                                <% if(i <= game.rating) { %>⭐<% } else { %>☆<% } %>
                            <% } %>
                        </p>

                        <div class="d-flex gap-2 mt-auto">
                            <a href="/list/details/<%= game.id %>" class="btn btn-primary">
                                View Details
                            </a>

                            <a href="/list/edit/<%= game.id %>" class="btn btn-warning">
                                Edit
                            </a>

                            <form action="/list/delete/<%= game.id %>" method="POST">
                                <button type="submit" class="btn btn-danger"
                                    onclick="return confirm('Delete <%= game.title %>?')">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <% }) %>
        </div>
    </div>
</body>
</html>