<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <title><%= game.title %> - Details</title>

    <style>
        body {
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
                        url("/Images/ListPage.gif") no-repeat center center/cover;
            min-height: 100vh;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            backdrop-filter: blur(5px);
            z-index: -1;
        }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="container mt-4">
        <h2 class="text-white fw-bold mb-4"><%= game.title %></h2>

        <div class="row">
            <div class="col-md-4">
                <img src="<%= game.image %>" 
                     alt="<%= game.title %>"
                     class="img-fluid rounded shadow"
                     style="width: 100%; object-fit: cover;">
            </div>

            <div class="col-md-8">
                <div class="card shadow" style="background-color: rgba(0,0,0,0.7); color: white; border: none;">
                    <div class="card-body">

                        <p><strong>ID:</strong> <%= game.id %></p>

                        <p><strong>Platform:</strong> <%= game.platform %></p>

                        <p><strong>Genre:</strong> <%= game.genre %></p>

                        <p><strong>Status:</strong>
                            <% if (game.status === 'Completed') { %>
                                <span class="badge bg-success">Completed</span>
                            <% } else if (game.status === 'Playing') { %>
                                <span class="badge bg-primary">Playing</span>
                            <% } else if (game.status === 'On Hold') { %>
                                <span class="badge bg-warning">On Hold</span>
                            <% } else if (game.status === 'Dropped') { %>
                                <span class="badge bg-danger">Dropped</span>
                            <% } else { %>
                                <span class="badge bg-secondary"><%= game.status %></span>
                            <% } %>
                        </p>

                        <p><strong>Rating:</strong>
                            <% for(let i = 1; i <= 5; i++) { %>
                                <% if(i <= game.rating) { %>⭐<% } else { %>☆<% } %>
                            <% } %>
                        </p>

                        <p><strong>Notes:</strong> <%= game.notes || '-' %></p>

                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <a href="/list/edit/<%= game.id %>" class="btn btn-warning">Edit</a>

                    <form action="/list/delete/<%= game.id %>" method="POST">
                        <button type="submit" class="btn btn-danger"
                            onclick="return confirm('Delete <%= game.title %>?')">
                            Delete
                        </button>
                    </form>

                    <a href="/ListPage" class="btn btn-secondary">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>