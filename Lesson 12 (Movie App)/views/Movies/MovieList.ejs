<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>My Watchlist</title>
    <style>
        body {
            background-color: #141414;
            min-height: 100vh;
        }

        .movie-card {
            background-color: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            color: white;
            overflow: hidden;
            height: 100%;
        }

        .movie-card img {
            height: 320px;
            object-fit: cover;
            width: 100%;
        }

        .card-body { padding: 16px; }

        h2 { color: white; }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">🎬 My Watchlist</h2>
            <a href="/Add" class="btn btn-danger">+ Add Movie</a>
        </div>

        <div class="row g-4">
            <% movies.forEach(movie => { %>
            <div class="col-md-4">
                <div class="movie-card h-100 shadow">
                    <img src="<%= movie.image %>" alt="<%= movie.title %>">
                    <div class="card-body d-flex flex-column">
                        <h5><%= movie.title %></h5>
                        <p class="mb-1"><strong>Genre:</strong> <%= movie.genre %></p>
                        <p class="mb-1"><strong>Status:</strong> <%= movie.status %></p>
                        <p class="mb-2"><strong>Rating:</strong>
                            <% for(let i = 1; i <= 5; i++) { %>
                                <% if(i <= movie.rating) { %>⭐<% } else { %>☆<% } %>
                            <% } %>
                        </p>
                        <div class="d-flex gap-2 mt-auto">
                            <a href="/movies/details/<%= movie.id %>" class="btn btn-primary btn-sm">Details</a>
                            <a href="/movies/edit/<%= movie.id %>" class="btn btn-warning btn-sm">Edit</a>
                            <form action="/movies/delete/<%= movie.id %>" method="POST">
                                <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('Delete <%= movie.title %>?')">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</body>
</html>
