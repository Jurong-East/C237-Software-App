<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Add Movie</title>
    <style>
        body { background-color: #141414; min-height: 100vh; }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="container mt-4 text-white" style="max-width: 600px;">
        <h2 class="fw-bold mb-4">🎬 Add a Movie</h2>

        <form action="/movies/add" method="POST">

            <div class="mb-3">
                <label for="title">Movie Title:</label>
                <input type="text" class="form-control" id="title" name="title" placeholder="Enter movie title" required>
            </div>

            <div class="mb-3">
                <label for="genre">Genre:</label>
                <select class="form-select" id="genre" name="genre">
                    <option value="">Select Genre</option>
                    <option value="Action">Action</option>
                    <option value="Comedy">Comedy</option>
                    <option value="Drama">Drama</option>
                    <option value="Horror">Horror</option>
                    <option value="Romance">Romance</option>
                    <option value="Sci-Fi">Sci-Fi</option>
                    <option value="Thriller">Thriller</option>
                    <option value="Animation">Animation</option>
                    <option value="Documentary">Documentary</option>
                    <option value="Other">Other</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="status">Status:</label>
                <select class="form-select" id="status" name="status">
                    <option value="">Select Status</option>
                    <option value="Plan to Watch">Plan to Watch</option>
                    <option value="Watching">Watching</option>
                    <option value="Completed">Completed</option>
                    <option value="Dropped">Dropped</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="rating">Rating:</label>
                <select class="form-select" id="rating" name="rating">
                    <option value="0">Not rated yet</option>
                    <option value="1">⭐★★★★ 1</option>
                    <option value="2">⭐⭐★★★ 2</option>
                    <option value="3">⭐⭐⭐★★ 3</option>
                    <option value="4">⭐⭐⭐⭐★ 4</option>
                    <option value="5">⭐⭐⭐⭐⭐ 5</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="notes">Notes:</label>
                <textarea class="form-control" id="notes" name="notes" rows="3" placeholder="Any thoughts on the movie?"></textarea>
            </div>

            <div class="mb-3">
                <label for="image">Movie Poster URL:</label>
                <input type="text" class="form-control" id="image" name="image" placeholder="Paste image URL here (optional)">
                <small class="text-white-50">Right-click any movie poster online → Copy Image Address → Paste here</small>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Add Movie</button>
                <a href="/MovieList" class="btn btn-secondary">Cancel</a>
            </div>

        </form>
    </div>
</body>
</html>
