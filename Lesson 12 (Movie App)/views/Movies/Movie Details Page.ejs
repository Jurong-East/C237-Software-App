<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title><%= movie.title %> - Details</title>
    <style>
        body { background-color: #141414; min-height: 100vh; }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="container mt-4">
        <h2 class="text-white fw-bold mb-4"><%= movie.title %></h2>

        <div class="row">
            <div class="col-md-4">
                <img src="<%= movie.image %>"
                     alt="<%= movie.title %>"
                     class="img-fluid rounded shadow"
                     style="width: 100%; object-fit: cover;">
            </div>

            <div class="col-md-8">
                <div class="card shadow" style="background-color: rgba(255,255,255,0.05); color: white; border: 1px solid rgba(255,255,255,0.1);">
                    <div class="card-body">

                        <p><strong>Genre:</strong> <%= movie.genre %></p>

                        <p><strong>Status:</strong>
                            <% if (movie.status === 'Completed') { %>
                                <span class="badge bg-success">Completed</span>
                            <% } else if (movie.status === 'Watching') { %>
                                <span class="badge bg-primary">Watching</span>
                            <% } else if (movie.status === 'Plan to Watch') { %>
                                <span class="badge bg-warning text-dark">Plan to Watch</span>
                            <% } else if (movie.status === 'Dropped') { %>
                                <span class="badge bg-danger">Dropped</span>
                            <% } else { %>
                                <span class="badge bg-secondary"><%= movie.status %></span>
                            <% } %>
                        </p>

                        <p><strong>Rating:</strong>
                            <% for(let i = 1; i <= 5; i++) { %>
                                <% if(i <= movie.rating) { %>⭐<% } else { %>☆<% } %>
                            <% } %>
                        </p>

                        <p><strong>Notes:</strong> <%= movie.notes || '-' %></p>

                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <a href="/movies/edit/<%= movie.id %>" class="btn btn-warning">Edit</a>
                    <form action="/movies/delete/<%= movie.id %>" method="POST">
                        <button type="submit" class="btn btn-danger"
                            onclick="return confirm('Delete <%= movie.title %>?')">
                            Delete
                        </button>
                    </form>
                    <a href="/MovieList" class="btn btn-secondary">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
